# NPM configuration for build reliability
# Increased timeouts to handle slower network connections
fetch-timeout=120000
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-retries=3

# Prefer offline mode to reduce network issues
prefer-offline=true

# Use exact versions to avoid unexpected updates
save-exact=true

# Legacy peer dependencies for compatibility
legacy-peer-deps=false

# Reduce build parallelism to avoid resource exhaustion
max-workers=2
