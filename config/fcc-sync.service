[Unit]
Description=FCC JustGo Sync Service
After=network-online.target

[Service]
Type=oneshot
User=fcc-web
WorkingDirectory=/home/fcc-web/FCCWebsite
ExecStart=/home/fcc-web/FCCWebsite/venv/bin/python /home/fcc-web/FCCWebsite/scripts/justgo-sync.py
StandardOutput=journal
StandardError=journal
Environment="JUSTGO_USER=%i"
Environment="JUSTGO_PASS=%i"
